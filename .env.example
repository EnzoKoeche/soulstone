# ─────────────────────────────────────────────────────────────
# Soulstone — variáveis de ambiente
# Copie para `.env` (raiz, p/ o poller) e `web/.env` (frontend) e preencha.
# NUNCA commitar segredos. Só este arquivo de exemplo é versionado.
# ─────────────────────────────────────────────────────────────

# ── Poller / Supabase Edge Function ──────────────────────────
# A service role key tem acesso total ao banco — mantenha em segredo.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Steam Market (dados PÚBLICOS, sem login)
STEAM_APPID=3678970
# Moeda do request: 1 = USD (preços vêm em centavos: 279 = US$2,79)
STEAM_CURRENCY=1
# Delay entre páginas para respeitar o rate limit da Steam (NFR-01)
POLL_PAGE_DELAY_MS=2500

# ── Frontend (Vite) — copie estes para web/.env ──────────────
# A anon key é pública por design (RLS protege o banco).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
